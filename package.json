{
  "name": "zoms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "portless zoms next dev",
    "dev:webpack": "portless zoms next dev --webpack",
    "build": "next build",
    "start": "portless zoms-preview next start",
    "lint": "biome check --write .",
    "check:types": "tsc --pretty --noEmit",
    "check:format": "biome format .",
    "check:lint": "biome lint .",
    "check": "biome check . && pnpm run check:types",
    "format": "biome format --write .",
    "test:unit": "tsx ./scripts/run-vitest.ts",
    "test:all": "pnpm run check && pnpm run test:unit",
    "test:all:build": "pnpm run test:all && pnpm run build",
    "db:generate": "tsx ./scripts/prisma-generate.ts",
    "db:generate:prod": "tsx ./scripts/prisma-generate-prod.ts",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force && pnpm run db:generate",
    "db:truncate": "tsx ./scripts/prisma-truncate.ts",
    "db:migrate": "tsx ./scripts/prisma-migrate.ts",
    "db:migrate:prod": "tsx ./scripts/prisma-migrate-prod.ts",
    "ai:reindex": "tsx src/lib/ingestion/cli.ts",
    "ai:reset": "tsx ./scripts/ai-reset.ts",
    "ai:reindex:prod": "tsx ./scripts/ai-reindex-prod.ts",
    "sanity:seed:projects": "tsx ./scripts/seed-sanity-projects.ts",
    "prepare": "husky",
    "studio:dev": "cd studio && pnpm run dev",
    "studio:build": "cd studio && pnpm run build",
    "studio:deploy": "cd studio && pnpm run deploy",
    "security:audit": "pnpm audit --prod",
    "security:check": "pnpm dlx audit-ci --config .audit-ci.json"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@portabletext/react": "^6.2.0",
    "@portabletext/types": "^4.0.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rehype-pretty/transformers": "^0.13.2",
    "@sanity/client": "^7.23.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.208",
    "botid": "^1.5.11",
    "dotenv": "^17.4.2",
    "next": "16.2.9",
    "next-sanity": "^13.1.1",
    "pg": "^8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "supermemory": "^4.24.12",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "26.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.5.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prisma": "^7.8.0",
    "sanity": "^6.1.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": "24.x.x"
  }
}
