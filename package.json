{
  "name": "zoms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "portless zoms next start",
    "lint": "biome check --write .",
    "check:types": "tsc --pretty --noEmit",
    "check:format": "biome format .",
    "check:lint": "biome lint .",
    "check": "biome check . && pnpm run check:types",
    "format": "biome format --write .",
    "test:unit": "tsx ./scripts/run-vitest.ts",
    "test:all": "pnpm run check && pnpm run test:unit",
    "test:all:build": "pnpm run test:all && pnpm run build",
    "prisma:generate": "tsx ./scripts/prisma-generate.ts",
    "prisma:generate:prod": "tsx ./scripts/prisma-generate-prod.ts",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:migrate": "tsx ./scripts/prisma-migrate.ts",
    "prisma:migrate:prod": "tsx ./scripts/prisma-migrate-prod.ts",
    "ai:reindex": "tsx src/lib/ingestion/cli.ts",
    "ai:reset": "tsx ./scripts/ai-reset.ts",
    "ai:reindex:prod": "tsx ./scripts/ai-reindex-prod.ts",
    "sanity:seed:projects": "tsx ./scripts/seed-sanity-projects.ts",
    "prepare": "husky",
    "studio:dev": "cd studio && pnpm run dev",
    "studio:build": "cd studio && pnpm run build",
    "studio:deploy": "cd studio && pnpm run deploy",
    "security:audit": "pnpm audit --prod",
    "security:check": "pnpm dlx audit-ci --config .audit-ci.json"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@langchain/textsplitters": "^1.0.1",
    "@neondatabase/serverless": "^1.0.2",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "@portabletext/react": "^6.0.3",
    "@portabletext/types": "^4.0.2",
    "@prisma/adapter-neon": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@rehype-pretty/transformers": "^0.13.2",
    "@sanity/client": "^7.20.0",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@upstash/vector": "^1.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.143",
    "botid": "^1.5.11",
    "dotenv": "^17.3.1",
    "next": "16.2.2",
    "next-sanity": "^12.2.1",
    "react": "19.2.4",
    "react-animated-counter": "^1.8.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-modal": "^3.16.3",
    "rehype-external-links": "^3.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "server-only": "^0.0.1",
    "supermemory": "^4.17.0",
    "tsparticles": "^3.9.1",
    "typewriter-effect": "^2.22.0",
    "unified": "^11.0.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-modal": "^3.16.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.2",
    "audit-ci": "^7.1.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-react-compiler": "^1.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "postcss": "8.5.8",
    "prisma": "^7.6.0",
    "sanity": "^5.19.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*": [
      "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
    ]
  },
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": "24.x.x"
  },
  "volta": {
    "node": "24.x.x"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": ">=3.14.2",
      "brace-expansion": ">=2"
    },
    "onlyBuiltDependencies": [
      "@tailwindcss/oxide",
      "@vercel/speed-insights",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "@tsparticles/engine",
      "protobufjs",
      "@prisma/engines",
      "prisma"
    ]
  }
}
