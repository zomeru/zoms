# Sanity CMS Configuration
# Get these values from https://www.sanity.io/manage

# Required for Sanity Studio and fetching data
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_APP_ID=your_app_id_here

# Optional: Only needed for write operations (e.g., seeding data, blog generation)
# Get this from https://www.sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your_write_token_here


# Blog Generation (Gemini AI)
# Get API key from https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Cron Job Authentication
# Generate a random secret for protecting the blog generation endpoint
# Used by Vercel Cron to authenticate weekly blog generation
CRON_SECRET=your_random_secret_here


# GitHub Stats (for lifetime coding statistics)
# Get token from https://github.com/settings/tokens
# Required scopes: public_repo (for public repos only) or repo (for private repos too)
# Note: Unauthenticated requests are limited to 60/hour by GitHub
# Authenticated requests get 5000/hour
GITHUB_TOKEN=your_github_token_here

# Optional: Override the GitHub username (defaults to 'zomeru')
GITHUB_USERNAME=zomeru

# Optional: Year you started coding on GitHub (used to bound the commit history query)
# Defaults to 2020
GITHUB_START_YEAR=2020


# WakaTime (for coding hours + language breakdown in the Dev Metrics card)
# Get your API key from https://wakatime.com/settings/api-key
# Required scopes: read_logged_time, read_stats
# Leave unset to disable the WakaTime section entirely
WAKATIME_API_KEY=your_wakatime_api_key_here


# Other Environment Variables
SITE_URL=http://localhost:3000

# Logging Configuration (nexlog)
# Optional: Configure logging behavior
# NEXLOG_LEVEL=debug                  # Log level: trace, debug, info, warn, error, fatal (default: info in prod, debug in dev)
# NEXLOG_STRUCTURED=true              # Enable structured JSON logging (default: true in prod, false in dev)

# Rate Limiting (Upstash Redis)
# Optional: For production rate limiting with distributed state
# If not provided, uses in-memory rate limiting (suitable for development)
# Get these from https://upstash.com/
# UPSTASH_REDIS_REST_URL=your_upstash_url_here
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here