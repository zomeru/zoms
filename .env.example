# Database (Supabase PostgreSQL via Prisma)
# DATABASE_URL: Pooled connection string used at runtime
# DIRECT_URL: Direct (non-pooled) connection string used for migrations
DATABASE_URL=""
DIRECT_URL=""

# Sanity CMS — used for blog content management
# NEXT_PUBLIC_SANITY_PROJECT_ID: Project ID from sanity.io/manage
# NEXT_PUBLIC_SANITY_DATASET: Dataset name (e.g. "production")
# SANITY_API_TOKEN: Write-access token for publishing AI-generated blog posts
# NEXT_PUBLIC_SANITY_APP_ID: Studio deployment app ID (used by `sanity deploy`)
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET=""
SANITY_API_TOKEN=""
NEXT_PUBLIC_SANITY_APP_ID=""

# Blog generation — AI-powered blog posts via Google Gemini
# BLOG_GENERATION_SECRET: Shared secret to authenticate POST /api/blog/generate requests
# GEMINI_API_KEY: Google Gemini API key (https://aistudio.google.com/apikey)
# GEMINI_MODEL: Gemini model ID to use for generation (e.g. "gemini-2.5-pro")
# CRON_SECRET: Vercel cron job secret; accepted as a fallback for BLOG_GENERATION_SECRET
BLOG_GENERATION_SECRET=""
GEMINI_API_KEY=""
GEMINI_MODEL=""
CRON_SECRET=""

# Upstash — serverless Redis for rate limiting
# UPSTASH_REDIS_REST_URL/TOKEN: Redis instance used for API rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# OpenRouter — LLM gateway for chat + embeddings (Vercel AI SDK via @openrouter/ai-sdk-provider)
# OPENROUTER_API_KEY: API key from openrouter.ai
# OPENROUTER_CHAT_MODEL: Model ID used for chat responses (e.g. "google/gemini-2.5-pro")
# OPENROUTER_EMBEDDING_MODEL: Model ID for pgvector embeddings. Must match IndexedDocument.embedding dim (2048).
#   Default: "nvidia/llama-nemotron-embed-vl-1b-v2" (2048 dims).
# OPENROUTER_BLOG_MODEL: Model ID used for AI-generated blog posts (optional; falls back to chat model if not set)
OPENROUTER_API_KEY=""
OPENROUTER_CHAT_MODEL=""
OPENROUTER_EMBEDDING_MODEL=""
OPENROUTER_BLOG_MODEL=""

# Developer stats — displayed on the portfolio
# GITHUB_TOKEN: Personal access token with read:user and repo scopes for the GitHub GraphQL API
# GITHUB_USERNAME: Your GitHub username (used in GraphQL queries for contributions/repos)
# WAKATIME_API_KEY: WakaTime API key for coding time and language breakdown stats
GITHUB_TOKEN=""
GITHUB_USERNAME=""
WAKATIME_API_KEY=""

# Google AdSense — blog monetisation (optional; ads are disabled if these are unset)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID: Publisher ID from adsense.google.com (e.g. "ca-pub-XXXXXXXXXXXXXXXXX")
# NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST: Ad unit slot ID shown between posts on /blog
# NEXT_PUBLIC_ADSENSE_SLOT_BLOG_POST: Ad unit slot ID shown inside individual blog posts
# NEXT_PUBLIC_ADSENSE_SLOT_PRIVACY: Ad unit slot ID shown on the /privacy page
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_LIST=""
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_POST=""
NEXT_PUBLIC_ADSENSE_SLOT_PRIVACY=""

# Other
# SITE_URL: Canonical origin of the site; required in production (e.g. "https://example.com")
# ENABLE_EXPERIMENTAL_COREPACK: Enables pnpm via Node.js Corepack
# AI_REINDEX_SECRET: Shared secret to authenticate POST /api/ai/reindex requests
SITE_URL="http://localhost:3000"
ENABLE_EXPERIMENTAL_COREPACK=1
AI_REINDEX_SECRET=""
SUPERMEMORY_API_KEY=your_api_key